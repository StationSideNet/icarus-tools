{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "exporter: run (json only)",
      "type": "node-terminal",
      "request": "launch",
      "command": "dotnet run -- --out=\"${workspaceFolder}/Exports\"",
      "cwd": "${workspaceFolder}/exporter",
      "autoAttachChildProcesses": false
    },
    {
      "name": "exporter: run (with textures)",
      "type": "node-terminal",
      "request": "launch",
      "command": "dotnet run -- --out=\"${workspaceFolder}/Exports\" --textures=\"${workspaceFolder}/Exports/texture-list.txt\"",
      "cwd": "${workspaceFolder}/exporter",
      "autoAttachChildProcesses": false
    },
    {
      "name": "exporter: run (textures only, no-clean)",
      "type": "node-terminal",
      "request": "launch",
      "command": "dotnet run -- --out=\"${workspaceFolder}/Exports\" --textures=\"${workspaceFolder}/Exports/texture-list.txt\" --no-clean",
      "cwd": "${workspaceFolder}/exporter",
      "autoAttachChildProcesses": false
    },
    {
      "name": "talent-transform: assets",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/talent-transform/scripts/assets.mjs",
      "cwd": "${workspaceFolder}/talent-transform",
      "console": "integratedTerminal"
    },
    {
      "name": "talent-transform: transform",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "transform"],
      "cwd": "${workspaceFolder}/talent-transform",
      "console": "integratedTerminal"
    },
    {
      "name": "talent-transform: validate",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "validate"],
      "cwd": "${workspaceFolder}/talent-transform",
      "console": "integratedTerminal"
    },
    {
      "name": "backfill: run",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/backfill.mjs",
      "console": "integratedTerminal"
    },
    {
      "name": "pipeline: full",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/pipeline.mjs",
      "console": "integratedTerminal"
    },
    {
      "name": "pipeline: skip export",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/pipeline.mjs",
      "args": ["--skip-export"],
      "console": "integratedTerminal"
    },
    {
      "name": "talent-app: dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/talent-app",
      "console": "integratedTerminal"
    },
    {
      "name": "talent-app: build",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
      "cwd": "${workspaceFolder}/talent-app",
      "console": "integratedTerminal"
    },
    {
      "name": "talent-app: run",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "cwd": "${workspaceFolder}/talent-app",
      "console": "integratedTerminal"
    }
  ]
}
